# Configuration reference — copy to `.env` and fill in.
# This lists the common settings; `bot/core/config.py` is the authoritative surface
# (every variable, with its default). Never commit a real `.env`.

# ── Mode ──────────────────────────────────────────────────────────────────────
DRY_RUN=true                       # true = simulate only; false = place real orders
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
POLY_VENUE=us                      # 'us' = Polymarket US (API-key auth); 'global' = CLOB (wallet auth)

# ── Kalshi credentials ────────────────────────────────────────────────────────
KALSHI_API_KEY=                    # Kalshi API key ID
KALSHI_PRIVATE_KEY_PATH=           # path to the Ed25519 / RSA private-key PEM file
KALSHI_ENV=demo                    # 'demo' or 'prod'

# ── Polymarket US credentials (POLY_VENUE=us) ─────────────────────────────────
POLYMARKET_US_KEY_ID=              # from polymarket.us/developer
POLYMARKET_US_SECRET_KEY=          # shown once at key creation — store securely

# ── Polymarket global credentials (POLY_VENUE=global) ─────────────────────────
PRIVATE_KEY=                       # Polygon wallet private key
FUNDER_ADDRESS=                    # wallet address

# ── Risk limits ───────────────────────────────────────────────────────────────
MAX_POSITION_USD=500               # max USDC per leg per trade
MAX_TOTAL_EXPOSURE=2000            # max USDC deployed across open positions
EVENT_COOLDOWN_SECONDS=300         # don't re-enter the same event within N seconds

# ── Loss caps (both default 0 = off) ──────────────────────────────────────────
KALSHI_EXEC_COST_BUDGET=0          # lifetime: halt after $X of realized losses
DAILY_LOSS_LIMIT=0                 # daily: halt after $X of realized losses in one day

# ── Notifications (optional) ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
